<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>DualPlay | Admin</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>

    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600&family=Poppins:wght@400;500&display=swap" rel="stylesheet"/>

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/public/favicon/logo.png" />

    <!-- Estilos -->
    <link rel="stylesheet" href="/public/css/admin.css">
    <link rel="stylesheet" href="/public/css/altaact.css">
  </head>

  <body>
    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg bg-body-tertiary">
      <div class="container-fluid">
        <a class="navbar-brand" href="#">DualPlay</a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item"><a class="nav-link active" href="#">Home</a></li>
            <li class="nav-item"><a class="nav-link" href="#">Videojuegos</a></li>
            <li class="nav-item"><a class="nav-link" href="#">Juegos de Mesa</a></li>
          </ul>
        </div>
      </div>
    </nav>

    <main id="main-actualizar">
      <div id="div-inputs">
        <div class="input-label">
          <label for="id-input">ID</label>
          <input class="form-control" id = "id-input" disabled="true" type="text">
        </div>
        <div class="input-label">
          <label for="tipo-input">Tipo</label>
          <input class="form-control" id = "tipo-input" disabled="true" type="text">
        </div>
        <div class="input-label">
          <label for="nombre-input">Nombre</label>
          <input class="form-control" id="nombre-input" type="text">
        </div>
        <div class="input-label">
          <label for="descripcion-input">Descripcion</label>
          <textarea class="form-control" id = "descripcion-input" type="text"></textarea>
        </div>
        <div class="input-label">
          <label for="precio-input">Precio</label>
          <input class="form-control" id = "precio-input" type="text">
        </div>
        <div class="input-label">
          <label for="imagen-input">Imagen</label>
          <input name="imagen" class="form-control" id = "imagen-input" type="file" accept="image/png, image/jpeg, image/jpg"/>
        </div>
      </div>
      <div>
        <button id="boton-actualizar" class="btn btn-primary"> Actualizar </button>
        <button id="boton-salir" class="btn btn-primary"> Salir </button>
      </div>
      
    </main>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/public/js/actualizacion.js"></script>
  </body>
</html>
